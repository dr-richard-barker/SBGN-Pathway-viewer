url: "https://github.com/dr-richard-barker/SBGN-Pathway-viewer"
keywords:
  - SBGN
  - KEGG
  - Reactome
  - pathway visualization
  - RNA-seq
  - transcriptomics
  - systems biology
  - FAIR
version: "1.0.0"
date-released: "2026-06-30"
